          "biologyPathway": [
              {
                  "title": "Refractive Error",
                  "short": "Focus lands in front of retina.",
                  "detail": "Myopia often happens when the eye is relatively long or focusing power is too strong."
              },
              {
                  "title": "Distance Blur",
                  "short": "Far objects blur.",
                  "detail": "Close objects may look clear while signs, screens, or distant faces blur."
              },
              {
                  "title": "Correction",
                  "short": "Lenses can refocus light.",
                  "detail": "Glasses, contacts, or refractive procedures can correct focus depending on the person."
              },
              {
                  "title": "Urgent Eye Signs",
                  "short": "Sudden changes are different.",
                  "detail": "Pain, flashes, floaters, curtain-like loss, or sudden blur needs eye care, not heroic squinting."
