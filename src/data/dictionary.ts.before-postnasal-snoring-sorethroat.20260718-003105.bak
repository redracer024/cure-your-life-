  {
    "id": "chest-tightness",
    "name": "Chest Tightness (Non-Cardiac)",
    "category": "Chest & Breathing",
    "tags": [
      "shallow breathing",
      "intercostal spasm",
      "anxiety loop",
      "grief"
    ],
    "riskLevel": "Medical monitoring recommended",
    "emotionalRoot": "Grief, constricted sorrow, self-protection against emotional pain, and withholding love (either giving or receiving it).",
    "metaphor": "Creating a 'bunker' around your heart to ensure no one can get close enough to hurt you, effectively suffocating yourself.",
    "physiologicalDescription": "Anxiety triggers shallow 'chest breathing' using accessory respiratory muscles (scalenes, pectoralis minor) rather than the diaphragm. This hyper-activates the intercostal muscles, creating a feeling of constriction, which then triggers more anxiety, culminating in a feedback loop of hyperventilation.",
    "sarcasticAdvice": "Yes, your 'heart chakra is bruised by the cruel world.' No, it has nothing to do with your complete lack of cardiovascular activity and your tendency to hold your breath every time you receive a mildly passive-aggressive work email.",
    "mindfulnessPrompts": [
      "What grief or old sadness am I carrying in my chest like a lead weight?",
      "What would happen if I took a full, uninhibited, deep breath right now?"
    ],
    "physicalTherapyTip": "Practice the 4-7-8 breathing technique (inhale for 4s, hold for 7s, exhale slowly for 8s) for 4 cycles to stimulate the vagus nerve and stretch the intercostals.",
    "biologyPath": [
      {
        "title": "Grief Shield",
        "description": "The emotional center contracts to protect the heart from painful interactions or old grief.",
        "expandedDetails": "A subconscious command activates defensive chest posture, physically pulling the shoulders forward and tightening the pectoral girdle."
      },
      {
        "title": "Apical Breathing",
        "description": "Your breathing pattern shifts entirely from the belly up to the collarbones.",
        "expandedDetails": "You stop using your diaphragm. Breathing becomes shallow and rapid, relying solely on upper rib cage expansion."
      },
      {
        "title": "Intercostal Strain",
        "description": "The small muscles between your ribs undergo chronic contraction and muscle fatigue.",
        "expandedDetails": "The intercostals and pectoralis minor muscles are forced to act as primary movers of respiration, leading to micro-spasms and local soreness."
      },
      {
        "title": "Oxygen Clamping",
        "description": "Shallow breathing alters carbon dioxide levels in the blood, triggering a brainstem alarm.",
        "expandedDetails": "A drop in arterial CO2 (hypocapnia) can contribute to systemic vasoconstriction and lightheadedness, which the brain interprets as an active lack of oxygen."
      },
      {
        "title": "Somatic Suffocation",
        "description": "A tight, iron band wraps around your lungs, making full expansion feel impossible.",
        "expandedDetails": "The physical constriction feedback loop is complete, generating a secondary panic wave that further locks up respiratory muscles."
      }
    ],
    "tones": {
      "clinical": {
        "mechanism": "Hyperventilation-induced hypocapnia may contribute to respiratory alkalosis, potentially interacting with intracellular calcium and contributing to mechanical spasms in the intercostal muscles and scalenes. This mechanical restriction inhibits vagal afferent feedback from pulmonary stretch receptors.",
        "protocol": [
          "Obtain an EKG and cardiac workup to conclusively rule out cardiovascular etiology before addressing psychosomatic patterns.",
          "Engage in diaphragmatic re-education, emphasizing prolonged exhalations to restore arterial pCO2 levels.",
          "Incorporate pectoral door-frame stretches to open the anterior myofascial chain."
        ],
        "citations": [
          "American Journal of Respiratory Medicine: 'Hyperventilation Syndrome and Intercostal Tension' (2023).",
          "Psychosomatic Medicine: 'Anxiety-Induced Respiratory Muscular Fatigue'."
        ]
      },
      "witty": {
        "metaphorTitle": "The Locked Heart Fortress",
        "metaphorText": "Your rib cage has converted itself into a medieval bunker designed to withstand a massive artillery strike.",
        "visualWarehouseDescription": "Imagine your chest cavity as a high-security vault. The drawbridge is raised, the archers are in position on the collarbones, and the doors are reinforced with steel bands. A tiny swallow of emotional sadness approaches. The guards immediately order a complete system lockdown. The gates slam shut so hard that the residents inside (your lungs) cannot even draw enough air to complain.",
        "wittyAdvice": "You don't need a bunker to survive a passive-aggressive email. Put down the weapons and let your rib cage expand."
      },
      "brutal": {
        "realityCheck": "Your breathing pattern may be holding back emotion, potentially increasing physical tension. You have stacked a decade of unexpressed grief in your chest and are now wondering why it feels like an elephant is sitting on your ribs. Crying won't kill you; holding your breath to pretend you are bulletproof will.",
        "protocolTitle": "Crack open the Armor",
        "protocolSteps": [
          "CRITICAL CHECKPOINT: If you are having chest pain radiating to your left arm or jaw, go to the emergency room. Otherwise, continue.",
          "Lie flat on your back on a hard floor. Put a thick book under your mid-back to force your chest open.",
          "Inhale deeply through your nose, hold it, and let out a loud, vocal sigh. Yes, make actual noise. Let the sadness out.",
          "Stop checking your pulse. Your heart is fine; it's just screaming for you to stop holding your breath."
        ]
      }
    },
    "medical_safety": {
      "critical_alerts": [
        "Chest pain, pressure, squeezing, or fullness",
        "Pain radiating to the arm, shoulder, neck, jaw, or back",
        "Severe shortness of breath or difficulty breathing",
        "Fainting, dizziness, or lightheadedness",
        "Bluish tint to lips, face, or fingernails (cyanosis)",
        "Coughing up blood or pink-tinged sputum"
      ],
      "seek_immediate_care_if": [
        "You experience sudden chest pain or pressure, especially if spreading to the arm, jaw, or back",
        "You have severe shortness of breath, feel faint, or develop blue lips",
        "A rapid, irregular, or fluttering heartbeat occurs suddenly along with sweating, nausea, or profound weakness"
