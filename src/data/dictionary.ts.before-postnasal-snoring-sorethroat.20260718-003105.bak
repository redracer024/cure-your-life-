  {
    "id": "chronic-insomnia",
    "name": "Chronic Insomnia",
    "category": "Skin & Sleep",
    "emotionalRoot": "Lack of trust in the process of life, fear of letting go of control, and carrying unresolved safety issues from the daytime into the dark.",
    "metaphor": "Believing that if you sleep, the world will collapse because you aren't awake to micro-manage it.",
    "physiologicalDescription": "Persistent cognitive rumination raises nocturnal cortisol and ACTH levels, preventing the natural core body temperature drop and melatonin secretion required for sleep. This keeps the brain locked in hyper-arousal (excessive beta-wave activity) instead of descending into slow-wave delta sleep.",
    "sarcasticAdvice": "Oh, absolutely, you have 'spectral disturbances in your bedroom.' It definitely has zero connection to you scrolling TikTok in pitch darkness with 100% blue light blasting directly into your retinas until 2 AM while drinking chamomile tea that was brewed with caffeinated water.",
    "mindfulnessPrompts": [
      "What am I afraid will happen if I completely surrender control for 8 hours?",
      "What unresolved safety or trust issue did I fail to address during the light of day?"
    ],
    "physicalTherapyTip": "Implement a strict 'no-screen' rule 60 minutes before bed. Keep your bedroom cold (around 65°F / 18°C) and practice progressive muscle relaxation starting from your toes up to your forehead.",
    "medical_safety": {
      "critical_alerts": [
        "Falling asleep or severe sleepiness while driving or operating machinery",
        "Sleep issues accompanied by chest pain, shortness of breath, or heart racing",
        "Waking up gasping, choking, or with a sudden sensation of suffocation",
        "Persistent fatigue accompanied by unexplained weight loss, fever, or night sweats",
        "Severe, overwhelming fatigue that may contribute to rapid functional decline",
        "Sleep disturbances accompanied by suicidal thoughts or severe mood disruption"
      ],
      "seek_immediate_care_if": [
        "You experience chest pain, severe shortness of breath, or fainting in connection with fatigue or waking up",
        "You experience suicidal thoughts, severe confusion, or sudden neurological deficits",
        "You are at risk of falling asleep while driving or doing other safety-critical activities"
      ],
      "schedule_care_if": [
        "You experience chronic, unrefreshing sleep or severe daytime sleepiness for more than a few weeks",
        "You have persistent, loud snoring with witnessed pauses in breathing (possible sleep apnea)",
        "You have unexplained weight loss, night sweats, or progressive fatigue that worsens despite rest"
      ],
      "self_care_allowed_if": "Maintaining consistent sleep hygiene, winding down without screens, and light exercise can support healthy natural sleep cycles.",
      "do_not_ignore": "Chronic fatigue and severe sleep disturbances can be indicators of cardiovascular strain, clinical depression, or sleep apnea, and need formal evaluation.",
      "disclaimer": "This app is for education and self-reflection only. It does not diagnose, treat, prevent, or cure disease. Seek professional medical care for diagnosis, treatment, medication decisions, or urgent symptoms."
    }
  },
  {
    "id": "tmj-jaw-clenching",
    "name": "TMJ & Jaw Clenching",
    "category": "Head & Neck",
    "emotionalRoot": "Suppressed anger, unspoken resentment, or holding back tears and sarcastic complaints to keep a polite face.",
    "metaphor": "Biting your tongue so hard that you are literally grinding down your own skeleton to prevent speaking your mind.",
    "physiologicalDescription": "Stress can contribute to hyper-activation of the trigeminal motor system, leading to nocturnal bruxism (jaw grinding). The masseter and temporalis muscles undergo chronic shortening and lactic acid accumulation, radiating pain to the temporomandibular joint, temples, and ears.",
    "sarcasticAdvice": "Splendid job keeping your mouth shut. Who needs a functioning jaw anyway when you can silently grind your teeth into fine porcelain dust instead of telling your mother-in-law what you actually think of her holiday cookies?",
    "mindfulnessPrompts": [
      "What words did I swallow today to maintain a peaceful facade?",
      "Who or what am I holding an unexpressed urge to bite back at?"
    ],
    "physicalTherapyTip": "Practice the 'lazy tongue' exercise: rest your tongue on the roof of your mouth and slowly open your jaw without letting the tongue lose contact. Massage the masseter muscle (just below the cheekbone) with warm fingers.",
    "medical_safety": {
      "critical_alerts": [
        "Sudden numbness or weakness of the face, arm, or leg (especially on one side)",
        "Sudden confusion, trouble speaking, or understanding speech",
        "Sudden trouble seeing in one or both eyes",
        "Sudden trouble walking, dizziness, loss of balance, or coordination",
        "Sudden, severe headache with no known cause ('thunderclap' headache)",
        "New onset of facial droop or facial muscle weakness"
      ],
      "seek_immediate_care_if": [
        "You experience sudden facial drooping, arm weakness, or slurred speech (the FAST stroke indicators)",
        "You have a sudden, blindingly severe headache or sudden loss of vision",
        "You experience a seizure, sudden confusion, or loss of consciousness"
      ],
      "schedule_care_if": [
        "You have frequent or progressively worsening headaches that interfere with sleep or work",
        "You experience occasional mild dizziness or subtle changes in coordination or memory",
        "You have persistent jaw pain or clicking that does not improve with stress reduction"
      ],
