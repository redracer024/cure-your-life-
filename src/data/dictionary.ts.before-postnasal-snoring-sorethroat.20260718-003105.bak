                  "tag": "Movement Symbol",
                  "paragraphs": [
                      "The rusty gate points to movement that has become costly.",
                      "Medical diagnosis determines whether the rust is wear, immune fire, crystals, injury, or infection."
                  ]
              },
              {
                  "layer": 5,
                  "title": "Bend Without Breaking",
                  "tag": "Reset Practice",
                  "paragraphs": [
                      "The reset is gentle movement, medical care, and emotional flexibility.",
                      "You are allowed to bend without surrendering your spine."
                  ]
              }
          ],
          "reset": {
              "title": "Joint Ease & Gate Oiling Reset",
              "modality": "Autonomic Downregulation",
              "steps": [
                  "Place one hand near the affected joint or on the heart if multiple joints hurt.",
                  "Inhale through the nose for 4 seconds.",
                  "Exhale through the mouth for 8 seconds.",
                  "Imagine warm oil moving through the joint without forcing it.",
                  "Whisper: I allow safe movement. I release unnecessary resistance."
              ]
          },
          "naturalSupport": {
              "title": "Supportive Care",
              "disclaimer": "Supportive care is not a cure. Arthritis type matters, and inflammatory or infected joints need medical care.",
              "items": [
                  {
                      "label": "Diagnosis first",
                      "detail": "OA, RA, psoriatic arthritis, gout, infection, injury, and autoimmune causes need different treatment."
                  },
                  {
                      "label": "Gentle movement",
                      "detail": "Range-of-motion and strengthening can support function when safe."
                  },
                  {
                      "label": "Heat or cold",
                      "detail": "Heat may reduce stiffness; cold may reduce swelling after activity or flare."
                  },
                  {
                      "label": "Risk tracking",
                      "detail": "Track morning stiffness, swelling, redness, warmth, fatigue, fever, rash, psoriasis, gout pattern, and affected joints."
                  }
              ],
              "avoid": [
                  "Do not ignore hot red swollen joints, fever, severe sudden pain, trauma, or rapidly worsening symptoms.",
                  "Do not delay care for suspected RA or inflammatory arthritis."
              ]
          },
          "brutalActions": [
              "Identify the arthritis type.",
              "Move gently instead of freezing solid.",
              "Do not ignore hot swollen joints.",
              "Bend on one thing emotionally, but get the joint checked medically."
          ]
      },
      "tones": {
          "clinical": {
              "mechanism": "Arthritis describes joint inflammation, pain, stiffness, swelling, and reduced motion. Causes include osteoarthritis, rheumatoid arthritis, psoriatic arthritis, gout, infection, lupus, injury, autoimmune disease, crystal disease, and other inflammatory or degenerative conditions.",
              "protocol": [
                  "Track joint pattern, swelling, redness, warmth, stiffness duration, fatigue, fever, rash, psoriasis, trauma, and function.",
                  "Seek urgent care for hot swollen joint, fever, severe pain, sudden swelling, trauma, or suspected infection.",
                  "Seek early evaluation for morning stiffness, symmetrical swelling, or possible inflammatory arthritis."
              ],
              "citations": [
                  "Educational reflection only; not a substitute for rheumatology or orthopedic care."
              ]
          },
          "witty": {
              "metaphorTitle": "The Rusty Gate",
              "metaphorText": "The hinge is stiff, the gate is screaming, and the farmer keeps pretending squeaking is a personality.",
              "wittyAdvice": "Oil the hinge, diagnose the rust, and stop treating inflammation like a motivational issue."
          },
          "brutal": {
              "realityCheck": "You may have an arthritis problem. You may also have a rigidity-and-resistance pattern.",
              "protocolTitle": "BEND WITHOUT BREAKING",
              "protocolSteps": [
                  "Identify the cause.",
                  "Move safely.",
                  "Treat inflammation.",
                  "Strengthen wisely.",
                  "Release unnecessary rigidity."
              ]
          }
      }
