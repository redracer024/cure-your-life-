  {
      "id": "alzheimers-disease",
      "name": "Alzheimer's Disease",
      "category": "Head & Neck",
      "emotionalRoot": "Memory grief, identity fear, fading connection, caregiver stress, and the human terror of losing the thread of self.",
      "metaphor": "The mind is a library where ink is fading, shelves are misfiled, and the lights in the memory wing are flickering.",
      "physiologicalDescription": "Alzheimer’s disease is a progressive neurodegenerative disease and common cause of dementia. It can cause worsening memory loss, disorientation, language difficulty, behavior/personality changes, functional decline, and caregiver burden. Diagnosis requires medical evaluation and ruling out other causes of cognitive decline.",
      "sarcasticAdvice": "Do not write off progressive memory loss as just aging. Brains do misplace keys; they should not slowly lose the map of the house.",
      "mindfulnessPrompts": [
          "What thread needs support?",
          "What practical planning is needed now?",
          "What change has someone else noticed?",
          "What care protects dignity?"
      ],
      "physicalTherapyTip": "Track memory changes, getting lost, medication mistakes, finances, behavior/personality changes, hallucinations, falls, driving safety, sleep, infections, depression, medication effects, and caregiver strain.",
      "medical_safety": {
          "critical_alerts": [
              "Sudden confusion or rapid cognitive decline",
              "Stroke symptoms: face droop, arm weakness, speech trouble, vision change",
              "Head injury, fever, severe headache, seizure, hallucinations, or delirium signs",
              "Unsafe wandering, medication mistakes, driving danger, falls, or self-neglect",
              "Caregiver burnout or unsafe home situation"
          ],
          "seek_immediate_care_if": [
              "Confusion is sudden or paired with stroke symptoms, fever, head injury, seizure, severe headache, or safety danger"
          ],
          "schedule_care_if": [
              "Memory loss is progressive, noticed by others, affecting daily life, driving, finances, meds, or behavior"
          ],
          "self_care_allowed_if": "Routine, sleep, social connection, exercise, and caregiver supports may help alongside medical evaluation.",
          "do_not_ignore": "Progressive memory loss is not just normal aging. Sudden confusion can be an emergency.",
          "disclaimer": "This app is for education and self-reflection only. It does not diagnose, treat, prevent, or cure disease."
      },
      "tags": [
          "alzheimer's",
          "dementia",
          "memory loss",
          "cognitive decline",
          "neurodegenerative"
      ],
      "riskLevel": "Medical monitoring recommended",
      "structuredContent": {
          "version": 1,
