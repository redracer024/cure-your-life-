  {
    "id": "stomach-intestinal-problems",
    "name": "Stomach & Intestinal Problems",
    "category": "Stomach & Gut",
    "emotionalRoot": "Dread, fear of the new, or feeling completely unable to digest, assimilate, or process incoming life events. Carrying deep, simmering anger at having to swallow situations you find intolerable.",
    "metaphor": "Your digestive engine grinding to a halt or burning itself up because you are trying to force-swallow and assimilate a toxic reality your soul absolutely rejects.",
    "physiologicalDescription": "Stress-induced sympathetic activation shifts blood flow away from the gut, alters mucosal barrier permeability ('leaky gut'), and disrupts the enteric nervous system, leading to chronic cramping, bloating, and dysbiosis.",
    "sarcasticAdvice": "Outstanding. Keep consuming stressful news feeds, toxic relationship dynamics, and high-pressure work assignments while expecting your stomach to digest them perfectly. I'm sure that your gut problems have absolutely nothing to do with what you are swallowing.",
    "mindfulnessPrompts": [
      "What situation, relationship, or news am I forcing myself to 'digest' that feels completely unpalatable?",
      "How can I set clear boundaries to stop swallowing toxic material, allowing my digestive core to heal?"
    ],
    "physicalTherapyTip": "Practice eating in a completely relaxed, screen-free environment. Spend 5 minutes performing slow, diaphragmatic breathing before meals to activate parasympathetic digestion ('rest and digest').",
    "medical_safety": {
      "critical_alerts": [
        "Vomiting blood or material that looks like coffee grounds",
        "Blood in your stool, or black, tarry, foul-smelling stools",
        "Severe, sudden, or progressively worsening abdominal pain",
        "Persistent vomiting and inability to keep any fluids down",
        "Signs of dehydration, such as extreme thirst, dry mouth, or little to no urine",
        "Yellowing of the skin or eyes (jaundice)"
      ],
      "seek_immediate_care_if": [
        "You vomit blood, pass black/tarry stools, or have severe, rigid abdominal pain",
        "You are severely dehydrated from persistent vomiting or diarrhea and cannot tolerate fluids",
        "You have sudden abdominal pain accompanied by a high fever and abdominal rigidity"
      ],
      "schedule_care_if": [
        "You experience unexplained weight loss, persistent diarrhea, or ongoing difficulty swallowing",
        "Your digestive symptoms last longer than two weeks or steadily worsen",
        "You develop new, unexplained changes in your bowel patterns or persistent bloating"
      ],
      "self_care_allowed_if": "A temporary bland diet, staying hydrated, and gentle abdomen massages can help soothe minor, stress-related digestive upset.",
      "do_not_ignore": "Persistent or severe digestive symptoms should never be ignored as they may indicate bleeding, ulceration, or bowel obstruction.",
      "disclaimer": "This app is for education and self-reflection only. It does not diagnose, treat, prevent, or cure disease. Seek professional medical care for diagnosis, treatment, medication decisions, or urgent symptoms."
    }
  },
