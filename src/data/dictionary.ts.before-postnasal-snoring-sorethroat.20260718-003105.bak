                  80,
                  300,
                  3000
              ],
              "uiBackgroundAccent": "#8B3A2A"
          },
          "hero": {
              "primaryPattern": "Lower esophageal sphincter function, reflux pressure, acid exposure, meal timing, and stress-related symptom sensitivity may amplify GERD patterns.",
              "cascade": [
                  "Pressure Builds",
                  "Valve Weakens",
                  "Acid Rises",
                  "Tissue Burns"
              ],
              "tags": [
