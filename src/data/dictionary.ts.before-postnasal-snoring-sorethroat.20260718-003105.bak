          "biologyPathway": [
              {
                  "title": "Disc Cushion",
                  "short": "Discs absorb load between vertebrae.",
                  "detail": "A disc has a tougher outer layer and softer inner material that helps absorb pressure."
              },
              {
                  "title": "Herniation",
                  "short": "Disc material bulges or leaks.",
                  "detail": "Disc material can irritate or compress nearby nerves, causing local and radiating symptoms."
              },
              {
                  "title": "Nerve Symptoms",
                  "short": "Pain can travel.",
                  "detail": "Lumbar discs can cause sciatica-like leg pain; cervical discs can radiate into the arm."
              },
              {
                  "title": "Emergency Signs",
                  "short": "Some nerve compression is urgent.",
                  "detail": "Bladder/bowel changes, saddle numbness, or progressive weakness can signal cauda equina or serious neurologic compromise."
