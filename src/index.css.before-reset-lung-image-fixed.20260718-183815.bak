@import url('https://fonts.googleapis.com/css2?family=Inter:ital,wght@0,300;0,400;0,500;0,600;0,700;0,800;1,400&family=JetBrains+Mono:wght@400;500;700;800&family=Space+Grotesk:wght@400;500;600;700;800;900&display=swap');
@import "tailwindcss";

@theme {
  --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
  --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, monospace;
  --font-display: "Space Grotesk", sans-serif;
}

html, body {
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  text-rendering: optimizeLegibility;
  backface-visibility: hidden;
  -webkit-backface-visibility: hidden;
}

@keyframes pulseGlow {
  0%, 100% {
    transform: scale(1) translate(0, 0);
    opacity: 0.15;
  }
  50% {
    transform: scale(1.15) translate(2%, 3%);
    opacity: 0.25;
  }
}

@keyframes pulseGlowCyan {
  0%, 100% {
    transform: scale(1.2) translate(0, 0);
    opacity: 0.15;
  }
  50% {
    transform: scale(0.95) translate(-3%, -2%);
    opacity: 0.25;
  }
}

@keyframes gridScroll {
  0% {
    background-position: 0 0;
  }
  100% {
    background-position: 40px 40px;
  }
}

.glowing-bg-grid {
  background-size: 42px 42px;
  background-image: 
    linear-gradient(rgba(255, 255, 255, 0.035) 1px, transparent 1px),
    linear-gradient(90deg, rgba(255, 255, 255, 0.035) 1px, transparent 1px);
  animation: gridScroll 35s linear infinite;
}

.premium-bg {
  background:
    radial-gradient(circle at 20% 20%, rgba(124, 58, 237, 0.18), transparent 30%),
    radial-gradient(circle at 80% 10%, rgba(249, 115, 22, 0.14), transparent 25%),
    radial-gradient(circle at 60% 80%, rgba(6, 182, 212, 0.12), transparent 30%),
    #05070b;
}

.category-card {
  position: relative;
  border: 1px solid rgba(255, 255, 255, 0.10);
  background:
    linear-gradient(145deg, rgba(255, 255, 255, 0.06), rgba(255, 255, 255, 0.02)),
    radial-gradient(circle at top left, var(--system-glow), transparent 45%);
  box-shadow:
    0 0 40px rgba(0, 0, 0, 0.35),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);
  backdrop-filter: blur(18px);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

/* Visual alphabetical ordering for the category grid.
   Current data order is preserved; the cards render as: All, Back, Chest, General, Head, Limbs, Metabolic, Skin, Stomach. */
.category-card:nth-child(1) { order: 1; } /* All */
.category-card:nth-child(8) { order: 2; } /* Back & Shoulders */
.category-card:nth-child(6) { order: 3; } /* Chest & Breathing */
.category-card:nth-child(4) { order: 4; } /* General & Energy */
.category-card:nth-child(3) { order: 5; } /* Head & Neck */
.category-card:nth-child(9) { order: 6; } /* Limbs & Joints */
.category-card:nth-child(2) { order: 7; } /* Metabolic & Endocrine */
.category-card:nth-child(7) { order: 8; } /* Skin & Sleep */
.category-card:nth-child(5) { order: 9; } /* Stomach & Gut */

.category-card:hover {
  transform: translateY(-6px) scale(1.015);
  border-color: var(--system-color);
  box-shadow: 0 0 45px var(--system-glow);
}

.icon-shell {
  width: 56px;
  height: 56px;
  border-radius: 18px;
  background: radial-gradient(circle, var(--system-glow), rgba(255, 255, 255, 0.04));
  border: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 0 0 24px var(--system-glow);
  transition: all 0.4s ease;
}

.category-card:hover .icon-shell {
  border-color: var(--system-color);
  box-shadow: 0 0 32px var(--system-color);
}

.radial-glow-indigo {
  filter: blur(120px);
  background: radial-gradient(circle, rgba(99, 102, 241, 0.3) 0%, transparent 70%);
  animation: pulseGlow 15s ease-in-out infinite alternate;
}

.radial-glow-cyan {
  filter: blur(120px);
  background: radial-gradient(circle, rgba(6, 182, 212, 0.22) 0%, transparent 70%);
  animation: pulseGlowCyan 18s ease-in-out infinite alternate;
}

.radial-glow-pink {
  filter: blur(100px);
  background: radial-gradient(circle, rgba(236, 72, 153, 0.15) 0%, transparent 70%);
  animation: pulseGlow 12s ease-in-out infinite alternate-reverse;
}

/* Glassmorphism custom effects */
.glass-panel {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.05) 0%, rgba(255, 255, 255, 0.01) 100%), rgba(7, 8, 15, 0.65);
  backdrop-filter: blur(12px) saturate(180%);
  border-top: 1px solid rgba(255, 255, 255, 0.15);
  border-left: 1px solid rgba(255, 255, 255, 0.15);
  border-bottom: 1px solid rgba(255, 255, 255, 0.04);
  border-right: 1px solid rgba(255, 255, 255, 0.04);
  box-shadow: 
    0 15px 35px 0 rgba(0, 0, 0, 0.5),
    inset 0 1px 1px 0 rgba(255, 255, 255, 0.1);
}

.glass-panel-heavy {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%), rgba(6, 7, 12, 0.85);
  backdrop-filter: blur(16px) saturate(200%);
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  border-left: 1px solid rgba(255, 255, 255, 0.2);
  border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  border-right: 1px solid rgba(255, 255, 255, 0.08);
  box-shadow: 
    0 30px 60px 0 rgba(0, 0, 0, 0.75),
    inset 0 1px 1px 0 rgba(255, 255, 255, 0.15);
}

.glass-panel-interactive {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.04) 0%, rgba(255, 255, 255, 0.01) 100%), rgba(7, 8, 15, 0.5);
  backdrop-filter: blur(10px) saturate(160%);
  border-top: 1px solid rgba(255, 255, 255, 0.12);
  border-left: 1px solid rgba(255, 255, 255, 0.12);
  border-bottom: 1px solid rgba(255, 255, 255, 0.03);
  border-right: 1px solid rgba(255, 255, 255, 0.03);
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
  box-shadow: 
    0 10px 30px 0 rgba(0, 0, 0, 0.4),
    inset 0 1px 1px 0 rgba(255, 255, 255, 0.08);
}

.glass-panel-interactive:hover {
  background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%), rgba(10, 12, 22, 0.6);
  border-top: 1px solid rgba(255, 255, 255, 0.2);
  border-left: 1px solid rgba(255, 255, 255, 0.2);
  transform: translateY(-4px);
  box-shadow: 
    0 25px 45px -10px rgba(0, 0, 0, 0.75),
    0 0 30px 0 rgba(99, 102, 241, 0.15),
    inset 0 1px 1px 0 rgba(255, 255, 255, 0.15);
}

/* Cinematic backing art for the symptom result boxes. */
.glass-panel-interactive,
.glass-panel-heavy {
  position: relative;
  isolation: isolate;
  --symptom-card-image: url('/all.png');
}

.glass-panel-interactive > *,
.glass-panel-heavy > * {
  position: relative;
  z-index: 2;
}

.glass-panel-interactive::before,
.glass-panel-heavy::before {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 0;
  pointer-events: none;
  background-image: var(--symptom-card-image);
  background-size: cover;
  background-position: center;
  opacity: 0.52;
  filter: blur(8px) saturate(1.45) contrast(1.2) brightness(1.15);
  transform: scale(1.1);
  transition: opacity 0.45s ease, transform 0.45s ease, filter 0.45s ease;
}

.glass-panel-interactive::after,
.glass-panel-heavy::after {
  content: "";
  position: absolute;
  inset: 0;
  z-index: 1;
  pointer-events: none;
  background:
    radial-gradient(circle at 52% 46%, rgba(255,255,255,0.04), transparent 36%),
    linear-gradient(90deg, rgba(3,5,10,0.88), rgba(3,5,10,0.58) 48%, rgba(3,5,10,0.74));
}

.glass-panel-interactive:hover::before,
.glass-panel-heavy:hover::before {
  opacity: 0.68;
  transform: scale(1.14);
  filter: blur(6px) saturate(1.6) contrast(1.25) brightness(1.22);
}

/* Match either hex style strings or browser-normalized RGB strings. Yes, it is dumb. CSS remains a haunted appliance. */
.glass-panel-interactive:has(span[style*="#FF6B2C"]),
.glass-panel-heavy:has(span[style*="#FF6B2C"]),
.glass-panel-interactive:has(span[style*="255, 107, 44"]),
.glass-panel-heavy:has(span[style*="255, 107, 44"]) { --symptom-card-image: url('/back-shoulders.png'); }

.glass-panel-interactive:has(span[style*="#FF4D4D"]),
.glass-panel-heavy:has(span[style*="#FF4D4D"]),
.glass-panel-interactive:has(span[style*="255, 77, 77"]),
.glass-panel-heavy:has(span[style*="255, 77, 77"]) { --symptom-card-image: url('/chest-breathing.png'); }

.glass-panel-interactive:has(span[style*="#FFD000"]),
.glass-panel-heavy:has(span[style*="#FFD000"]),
.glass-panel-interactive:has(span[style*="255, 208, 0"]),
.glass-panel-heavy:has(span[style*="255, 208, 0"]) { --symptom-card-image: url('/limbs-joints.png'); }

.glass-panel-interactive:has(span[style*="#B15CFF"]),
.glass-panel-heavy:has(span[style*="#B15CFF"]),
.glass-panel-interactive:has(span[style*="177, 92, 255"]),
.glass-panel-heavy:has(span[style*="177, 92, 255"]) { --symptom-card-image: url('/head-neck.png'); }

.glass-panel-interactive:has(span[style*="#FF8A00"]),
.glass-panel-heavy:has(span[style*="#FF8A00"]),
.glass-panel-interactive:has(span[style*="255, 138, 0"]),
.glass-panel-heavy:has(span[style*="255, 138, 0"]) { --symptom-card-image: url('/metabolic-endocrine.png'); }

.glass-panel-interactive:has(span[style*="#00E676"]),
.glass-panel-heavy:has(span[style*="#00E676"]),
.glass-panel-interactive:has(span[style*="0, 230, 118"]),
.glass-panel-heavy:has(span[style*="0, 230, 118"]) { --symptom-card-image: url('/stomach-gut.png'); }

.glass-panel-interactive:has(span[style*="#FF5CD6"]),
.glass-panel-heavy:has(span[style*="#FF5CD6"]),
.glass-panel-interactive:has(span[style*="255, 92, 214"]),
.glass-panel-heavy:has(span[style*="255, 92, 214"]) { --symptom-card-image: url('/skin-sleep.png'); }
